    {
      "parameters": {
        "jsCode": "const rows = items\n  .map(i => i.json)\n  .filter(r =>\n    r[\"TP/Loss\"] !== \"NO\" &&\n    r[\"R:R\"] !== \"NO\"\n  )\n  .map(r => {\n    const rawID_Post = String(r[\"ID_Post\"]); // 👈 ép về string\n\n    return {\n      ID_Post: rawID_Post.replace(\"_Result\", \"\"), // luôn là string\n      tp_loss: r[\"TP/Loss\"],\n      rr: Number(String(r[\"R:R\"]).replace(\"R\", \"\"))\n    };\n  });\n\nreturn [\n  {\n    json: {\n      trades: rows\n    }\n  }\n];\n"
      },
