    {
      "parameters": {
        "jsCode": "// Lấy text AI trả về\nconst text = $json.output[0].content[0].text;\n\n// Parse JSON string\nconst data = JSON.parse(text);\n\n// Convert thành n8n items\nreturn data.map(row => ({\n  json: {\n    \"ID_Post\": Number(row.ID_Post),\n    \"R:R\": row.final_rr + \"R\",\n    \"Reason\": row.reason,\n    \"TP\" : row.tp_hit\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
